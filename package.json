{
  "name": "streamvault",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\" --names \"frontend,backend\" --prefix-colors \"cyan,magenta\"",
    "dev:frontend": "vite",
    "dev:backend": "cd backend && bun --watch src/index.ts",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "bun test ./src",
    "test:backend": "cd backend && bun test",
    "e2e": "playwright test",
    "e2e:ci": "playwright test --project='Desktop Chrome' --reporter=list,html --grep-invert @skip-ci",
    "e2e:ui": "playwright test --ui"
  },
